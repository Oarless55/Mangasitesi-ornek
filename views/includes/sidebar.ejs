<div class="sidebar-col col-md-4 col-sm-4">
    <div id="main-sidebar" class="main-sidebar" role="complementary">
        <div class="row">

        </div>
        <div class="row">
            <div id="manga-recent-4"
                class="widget col-xs-12 col-md-12   bordered  no-icon heading-style-1 c-popular manga-widget widget-manga-recent">
                <div class="widget__inner c-popular manga-widget widget-manga-recent__inner c-widget-wrap">
                    <div class="c-widget-content style-1 with-button">
                        <!-- Tab Controls -->
                        <div class="widget-tabs d-flex" style="background: rgba(var(--ui-bg-color), 0.1); border-radius: 25px; margin-bottom: 15px; border: 1px solid rgba(128,128,128,0.2);">
                            <a href="javascript:void(0)" class="stat-tab-link active" data-target="weekly" style="flex:1; text-align:center; padding: 8px; border-radius: 25px; font-weight:bold; font-size: 13px; color: #fff; background: #e53935; text-decoration: none; transition: 0.3s;">Haftalık</a>
                            <a href="javascript:void(0)" class="stat-tab-link" data-target="monthly" style="flex:1; text-align:center; padding: 8px; border-radius: 25px; font-weight:bold; font-size: 13px; color: #aaa; text-decoration: none; transition: 0.3s;">Aylık</a>
                            <a href="javascript:void(0)" class="stat-tab-link" data-target="alltime" style="flex:1; text-align:center; padding: 8px; border-radius: 25px; font-weight:bold; font-size: 13px; color: #aaa; text-decoration: none; transition: 0.3s;">Tüm Zamanlar</a>
                        </div>
                        
                        <div class="widget-content">
                            
                            <!-- HAFTALIK SEKME -->
                            <div id="stat-weekly" class="stat-tab-content">
                                <% for (let item of topWeekly) { let {story} = item; %>
                                    <div class="stat-item-wrap" style="display:flex; align-items:center; background: rgba(0,0,0,0.3); border-radius: 12px; margin-bottom: 10px; padding: 10px; transition: transform 0.2s;">
                                        <a href="/manga/<%= story.slug %>.<%= story._id %>" style="flex-shrink:0;">
                                            <img width="50" height="70" src="<%= webAssets(story.avatar) %>" style="border-radius:6px; object-fit:cover;">
                                        </a>
                                        <div style="margin-left: 15px; flex-grow: 1; overflow:hidden;">
                                            <h5 style="margin:0 0 5px 0; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <a href="/manga/<%= story.slug %>.<%= story._id %>" style="color:inherit;"><%= story.title %></a>
                                            </h5>
                                            <span style="font-size: 12px; color: #aaa;"><i class="icon ion-md-eye"></i> <%= (story.viewsWeekly || 0).toLocaleString('tr-TR') %> görüntüleme</span>
                                        </div>
                                    </div>
                                <% } %>
                            </div>

                            <!-- AYLIK SEKME -->
                            <div id="stat-monthly" class="stat-tab-content" style="display:none;">
                                <% for (let item of topMonthly) { let {story} = item; %>
                                    <div class="stat-item-wrap" style="display:flex; align-items:center; background: rgba(0,0,0,0.3); border-radius: 12px; margin-bottom: 10px; padding: 10px; transition: transform 0.2s;">
                                        <a href="/manga/<%= story.slug %>.<%= story._id %>" style="flex-shrink:0;">
                                            <img width="50" height="70" src="<%= webAssets(story.avatar) %>" style="border-radius:6px; object-fit:cover;">
                                        </a>
                                        <div style="margin-left: 15px; flex-grow: 1; overflow:hidden;">
                                            <h5 style="margin:0 0 5px 0; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <a href="/manga/<%= story.slug %>.<%= story._id %>" style="color:inherit;"><%= story.title %></a>
                                            </h5>
                                            <span style="font-size: 12px; color: #aaa;"><i class="icon ion-md-eye"></i> <%= (story.viewsMonthly || 0).toLocaleString('tr-TR') %> görüntüleme</span>
                                        </div>
                                    </div>
                                <% } %>
                            </div>

                            <!-- TÜM ZAMANLAR SEKME -->
                            <div id="stat-alltime" class="stat-tab-content" style="display:none;">
                                <% for (let item of topTrending) { let {story} = item; %>
                                    <div class="stat-item-wrap" style="display:flex; align-items:center; background: rgba(0,0,0,0.3); border-radius: 12px; margin-bottom: 10px; padding: 10px; transition: transform 0.2s;">
                                        <a href="/manga/<%= story.slug %>.<%= story._id %>" style="flex-shrink:0;">
                                            <img width="50" height="70" src="<%= webAssets(story.avatar) %>" style="border-radius:6px; object-fit:cover;">
                                        </a>
                                        <div style="margin-left: 15px; flex-grow: 1; overflow:hidden;">
                                            <h5 style="margin:0 0 5px 0; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <a href="/manga/<%= story.slug %>.<%= story._id %>" style="color:inherit;"><%= story.title %></a>
                                            </h5>
                                            <span style="font-size: 12px; color: #aaa;"><i class="icon ion-md-eye"></i> <%= (story.views || 0).toLocaleString('tr-TR') %> görüntüleme</span>
                                        </div>
                                    </div>
                                <% } %>
                            </div>

                            <script>
                                document.addEventListener("DOMContentLoaded", () => {
                                    const tabs = document.querySelectorAll('.stat-tab-link');
                                    const contents = document.querySelectorAll('.stat-tab-content');
                                    tabs.forEach(tab => {
                                        tab.addEventListener('click', (e) => {
                                            tabs.forEach(t => {
                                                t.style.background = 'transparent';
                                                t.style.color = '#aaa';
                                            });
                                            e.target.style.background = '#e53935';
                                            e.target.style.color = '#fff';
                                            
                                            contents.forEach(c => c.style.display = 'none');
                                            document.getElementById('stat-' + e.target.getAttribute('data-target')).style.display = 'block';
                                        });
                                    });
                                });
                            </script>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== LEVEL SIRALAMASI WIDGET ===== -->
        <% if (typeof top10Users !== 'undefined' && top10Users && top10Users.length > 0) { %>
        <div class="row" style="margin-top: 20px;">
            <div class="widget col-xs-12 col-md-12 bordered no-icon heading-style-1">
                <div class="widget__inner c-widget-wrap">
                    <!-- Başlık -->
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:15px; padding-bottom:12px; border-bottom: 1px solid rgba(255,255,255,0.08);">
                        <div style="width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#f7971e,#ffd200); display:flex; align-items:center; justify-content:center; font-size:16px; box-shadow:0 0 12px rgba(255,210,0,0.4);">🏆</div>
                        <h3 style="margin:0; font-size:15px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:#ffd200;">Level Sıralaması</h3>
                    </div>

                    <!-- Liste -->
                    <% top10Users.forEach(function(u, idx) {
                        let reads = u.totalReadChapters || 0;
                        let lvl = 1, title = 'Acemi', color = '#78909c';
                        if (reads > 500)      { lvl = 5; title = 'Manga Tanrısı'; color = '#ab47bc'; }
                        else if (reads > 300) { lvl = 4; title = 'Efsanevi';      color = '#ffd700'; }
                        else if (reads > 150) { lvl = 3; title = 'Usta';          color = '#42a5f5'; }
                        else if (reads > 50)  { lvl = 2; title = 'Deneyimli';     color = '#66bb6a'; }
                        
                        let medal = '';
                        if (idx === 0) medal = '🥇';
                        else if (idx === 1) medal = '🥈';
                        else if (idx === 2) medal = '🥉';
                        else medal = (idx + 1) + '.';
                    %>
                    <div style="display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:10px; margin-bottom:6px; background: rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05); transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
                        <!-- Sıra -->
                        <div style="width:28px; text-align:center; font-size:<%= idx < 3 ? '18px' : '13px' %>; font-weight:700; color:#aaa; flex-shrink:0;"><%= medal %></div>
                        <!-- Avatar -->
                        <img src="<%= u.avatar || 'https://i.imgur.com/pqGLgGr.jpg' %>" alt="<%= u.name %>" style="width:36px; height:36px; border-radius:50%; object-fit:cover; border:2px solid <%= color %>; flex-shrink:0;">
                        <!-- İsim + Unvan -->
                        <div style="flex-grow:1; overflow:hidden;">
                            <div style="font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= u.name %></div>
                            <div style="font-size:11px; color:<%= color %>; font-weight:500;">Lv.<%= lvl %> · <%= title %></div>
                        </div>
                        <!-- Bölüm sayısı -->
                        <div style="text-align:right; flex-shrink:0;">
                            <div style="font-size:13px; font-weight:700; color:<%= color %>;"><%= reads %></div>
                            <div style="font-size:10px; color:#666;">bölüm</div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
        <% } %>
        <!-- ===== / LEVEL SIRALAMASI ===== -->

    </div>
</div>