<html lang="en-US">

<%- include( 'includes/head' , { title: 'Kişiselleştirme' , description: 'Manga oku' , seo_image: process.env.DOMAIN
    + '/images/share.jpg' , showAds: false } ); -%>


    <body class="page <%= lightTheme ? '' : 'text-ui-light' %>">
        <div id="app" class="wrap">
            <div class="body-wrap">
                <%- include('includes/header') -%>
                    <div class="site-content">
                        <div class="c-page-content style-2">
                            <div class="content-area">
                                <div class="container">
                                    <div class="row ">
                                        <div class="col-md-12 col-sm-12">
                                            <div class="main-col-inner">
                                                <div id="post-5"
                                                    class="c-blog-post post-5 page type-page status-publish hentry">
                                                    <div class="entry-header">
                                                        <div class="entry-header_wrap">
                                                            <div class="entry-title">
                                                                <h1 class="item-title h2">Ayarlar</h1>
                                                            </div>
                                                        </div>
                                                    </div>


                                                    <div class="entry-content">
                                                        <div class="entry-content_wrap">
                                                            <div class="row settings-page">
                                                                <div class="col-md-3 col-sm-3">
                                                                    <tab-bar></tab-bar>
                                                                </div>
                                                                <div class="col-md-9 col-sm-9">
                                                                    <% if (typeof user !== 'undefined' && user && typeof cloudLibrary !== 'undefined' && cloudLibrary.stats) { %>
                                                                    <div class="gamification-board" style="background: linear-gradient(135deg, #1e1e24 0%, #2a2a35 100%); border-radius: 15px; padding: 25px; color: #fff; margin-bottom: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                                                                        
                                                                        <div style="position: absolute; top: -20px; right: -20px; opacity: 0.05; font-size: 180px; z-index: 1;">
                                                                           <i class="icon ion-ios-trophy"></i>
                                                                        </div>

                                                                        <div style="position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
                                                                            <div style="display: flex; align-items: center; gap: 20px; flex: 1; min-width: 250px;">
                                                                                <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(45deg, #ff416c, #ff4b2b); display: flex; align-items: center; justify-content: center; font-size: 26px; font-weight: bold; border: 4px solid #1a1a24; box-shadow: 0 0 20px rgba(255, 65, 108, 0.4); flex-shrink: 0;">
                                                                                    Lv.<%= cloudLibrary.stats.currentLevel %>
                                                                                </div>
                                                                                <div>
                                                                                    <h3 style="margin: 0 0 5px 0; font-size: 24px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 1px;"><%= cloudLibrary.stats.levelTitle %></h3>
                                                                                    <p style="margin: 0; color: #aaa; font-size: 14px;">Sitemizde bugüne kadar tam <b style="color:#fff;"><%= cloudLibrary.stats.totalReads %></b> bölüm okudunuz.</p>
                                                                                </div>
                                                                            </div>
                                                                            
                                                                            <div style="text-align: right; flex: 1; min-width: 220px;">
                                                                                <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 13px; color: #ccc;">
                                                                                    <span>Deneyim Barı</span>
                                                                                    <span>HEDEF: <b><%= cloudLibrary.stats.nextThreshold %> Bölüm</b></span>
                                                                                </div>
                                                                                <div style="width: 100%; height: 12px; background: rgba(0,0,0,0.5); border-radius: 6px; overflow: hidden; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);">
                                                                                    <div class="xp-bar-inner" style="width: <%= cloudLibrary.stats.percentage %>%; height: 100%; background: linear-gradient(90deg, #ff416c, #ff4b2b); border-radius: 6px; transition: width 1.5s ease-out;"></div>
                                                                                </div>
                                                                                <div style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 10px;">
                                                                                    <span style="background: rgba(255, 255, 255, 0.08); padding: 6px 14px; border-radius: 20px; font-size: 12px; border: 1px solid rgba(255,255,255,0.15); display: inline-flex; align-items: center; gap: 5px;">
                                                                                        <i class="icon ion-md-flame" style="color: #ff4b2b;"></i> 
                                                                                        Favori Türün: <b style="color: #fff;"><%= cloudLibrary.stats.favoriteGenre %></b>
                                                                                    </span>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>

                                                                    <% if (typeof cloudLibrary !== 'undefined' && cloudLibrary.badges && cloudLibrary.badges.length > 0) { %>
                                                                    <div class="user-badges-board" style="background: #1e1e24; border-radius: 15px; padding: 20px; color: #fff; margin-bottom: 25px; border: 1px solid rgba(255,215,0,0.2);">
                                                                        <h4 style="margin-top:0; margin-bottom: 15px; color: #ffd700;"><i class="fas fa-medal"></i> Kazanılan Rozetler</h4>
                                                                        <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                                                                            <% cloudLibrary.badges.forEach(function(badge) { %>
                                                                                <div style="text-align: center; width: 80px;">
                                                                                    <div class="badge-item" style="width: 50px; height: 50px; font-size: 24px; margin: 0 auto 8px auto;" data-title="<%= badge.description %>">
                                                                                        <i class="<%= badge.icon %>"></i>
                                                                                    </div>
                                                                                    <div style="font-size: 11px; color: #ccc; line-height: 1.2;"><%= badge.name %></div>
                                                                                </div>
                                                                            <% }); %>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>

                                                                    <div class="tabs-content-wrap">
                                                                        <div class="tab-content">
                                                                            <div class="tab-pane active" style="position: relative;">
                                                                                <div id="vue-router-container">
                                                                                    <router-view
                                                                                        user="<%= JSON.stringify(user) %>"></router-view>
                                                                                </div>
                                                                                
                                                                                <div id="custom-history-view" style="display: none; width: 100%;">
                                                                                    <h4 style="margin-bottom: 20px;">Okuma Geçmişim</h4>
                                                                                    <div id="history-grid"></div>
                                                                                </div>
                                                                                <div id="custom-bookmark-view" style="display: none; width: 100%;">
                                                                                    <h4 style="margin-bottom: 20px;">Takip Ettiğim Seriler</h4>
                                                                                    <div id="bookmark-grid"></div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <%- include('includes/footer') -%>
            </div>
            <!-- Modal -->
            <%- include('includes/popup-session') -%>
        </div>

        <div class="align-items-center d-flex go-to-top justify-content-center active">
            <i class="icon ion-md-arrow-up"></i>
        </div>


        <%- include('includes/script-core') -%>

        <script>
        document.addEventListener("DOMContentLoaded", () => {
            const vueContainer = document.getElementById('vue-router-container');
            const historyView = document.getElementById('custom-history-view');
            const bookmarkView = document.getElementById('custom-bookmark-view');
            
            const historyGrid = document.getElementById('history-grid');
            const bookmarkGrid = document.getElementById('bookmark-grid');

            const isUserLoggedIn = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
            const cloudLibraryRaw = <%- typeof cloudLibrary !== 'undefined' && cloudLibrary ? JSON.stringify(cloudLibrary) : 'null' %>;
            
            let finalHistoryData = [];
            let finalBookmarkData = [];
            
            if (isUserLoggedIn && cloudLibraryRaw) {
               finalHistoryData = cloudLibraryRaw.history.map(h => ({
                   id: h.story._id,
                   title: h.story.title,
                   slug: h.story.slug,
                   avatar: typeof h.story.avatar === 'string' && h.story.avatar.includes('http') ? h.story.avatar : ('/upload/' + h.story.avatar),
                   chapterUrl: h.chapterUrl,
                   chapterName: h.chapterName
               }));
               finalBookmarkData = cloudLibraryRaw.bookmarks.map(b => ({
                   id: b._id,
                   title: b.title,
                   slug: b.slug,
                   avatar: typeof b.avatar === 'string' && b.avatar.includes('http') ? b.avatar : ('/upload/' + b.avatar)
               }));
            }

            function renderMangas(container, storageKey, emptyMessage, cloudDataOverride) {
                try {
                    let data = [];
                    if (isUserLoggedIn) {
                        data = cloudDataOverride || [];
                    } else {
                        data = JSON.parse(localStorage.getItem(storageKey) || '[]');
                    }

                    if (data.length === 0) {
                        container.innerHTML = `<p>${emptyMessage}</p>`;
                        return;
                    }
                    let html = '<div class="row">';
                    data.forEach(m => {
                        // Link goes to chapter if history, or story if bookmark
                        const link = m.chapterUrl ? m.chapterUrl : `/manga/${m.slug}.${m.id}`;
                        const badge = m.chapterName ? `<div style="position: absolute; bottom: 0; background: rgba(0,0,0,0.8); color: #fff; width: 100%; font-size: 12px; padding: 3px;">${m.chapterName}</div>` : '';
                        
                        html += `
                            <div class="col-xs-6 col-sm-4 col-md-3">
                                <div class="manga-item" style="margin-bottom: 25px; text-align: center;">
                                    <a href="${link}" style="color: #fff; text-decoration: none;">
                                        <div style="position: relative; width: 100%; padding-bottom: 140%; overflow: hidden; border-radius: 5px;">
                                            <img src="${m.avatar}" style="position: absolute; top:0; left:0; width:100%; height:100%; object-fit: cover;">
                                            ${badge}
                                        </div>
                                        <h5 style="margin-top: 10px; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${m.title.replace(/"/g, '&quot;')}">${m.title}</h5>
                                    </a>
                                </div>
                            </div>
                        `;
                    });
                    html += '</div>';
                    container.innerHTML = html;
                } catch(e) {
                    container.innerHTML = `<p>${emptyMessage}</p>`;
                }
            }

            function checkRoute() {
                const path = window.location.pathname + window.location.hash;
                const isHistory  = path.includes('history')  || path.includes('gecmis')  || path.includes('Lịch Sử');
                const isBookmark = path.includes('bookmark') || path.includes('takip')   || path.includes('Theo Dõi');
                
                if (isHistory) {
                    vueContainer.style.display = 'none';
                    historyView.style.display = 'block';
                    bookmarkView.style.display = 'none';
                    if (!historyGrid.dataset.rendered) {
                        renderMangas(historyGrid, 'manga_history', 'Henüz okuduğunuz bir seri bulunmuyor.', finalHistoryData);
                        historyGrid.dataset.rendered = '1';
                    }
                } else if (isBookmark) {
                    vueContainer.style.display = 'none';
                    bookmarkView.style.display = 'block';
                    historyView.style.display = 'none';
                    if (!bookmarkGrid.dataset.rendered) {
                        renderMangas(bookmarkGrid, 'manga_bookmarks', 'Henüz takip ettiğiniz bir seri bulunmuyor.', finalBookmarkData);
                        bookmarkGrid.dataset.rendered = '1';
                    }
                } else {
                    vueContainer.style.display = 'block';
                    historyView.style.display = 'none';
                    bookmarkView.style.display = 'none';
                }
            }

            setInterval(checkRoute, 300);
            checkRoute();
        });
        </script>

    </body>

</html>